# 환경변수 템플릿 — 이 파일은 GitHub에 push 가능 (실제 키 없음)
# 실제 사용:
#   1. 이 파일을 .env로 복사: cp .env.example .env
#   2. 아래 값을 본인 키로 교체
#   3. .env는 .gitignore에 의해 push 차단됨

# OpenAI API 키 (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-api-key-here

# KRX 한국거래소 OpenAPI 인증키 (http://openapi.krx.co.kr/)
KRX_AUTH_KEY=your-krx-auth-key-here
